#!/usr/bin/env python3

from configparser import ConfigParser
from pathlib import Path
from time import time

cutoff = time() - 30 * 86400

config = ConfigParser()
config.read("@SYSCONFDIR@/aprox.conf")
config = config["main"]

archives = Path(config["archives"])
if archives.is_dir():
    for f in archives.rglob("*.deb"):
        if f.stat().st_mtime < cutoff:
            print(f.relative_to(archives))
            f.unlink()
